# MQTT
BROKER_HOST=mqtt
BROKER_PORT=1883
TOPIC=simulation/images

# RabbitMQ
RABBITMQ_HOST=rabbitmq
CLOUD_UPLOAD_QUEUE=cloud_upload_queue

# MinIO
CLOUD_ENDPOINT=minio:9000
CLOUD_ACCESS_KEY=minioadmin
CLOUD_SECRET_KEY=minioadmin
CLOUD_BUCKET=retraining-data

# Image Streamer
IMAGE_FOLDER=/dataset/Broken stitch
DELAY_SECONDS=0.066

# Prediction / Alerting
CONFIDENCE_THRESHOLD=0.90
SEEN_CLASSES=Broken stitch,defect free,hole,horizontal
