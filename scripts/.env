# --- MQTT Broker ---
BROKER_HOST=localhost
BROKER_PORT=1883
TOPIC=simulation/images

# --- Image Streamer ---
IMAGE_FOLDER=../Dataset/Broken stitch
DELAY_SECONDS=0.066

# --- Image Receiver ---
OUTPUT_DIR=received_images

# --- Cloud Uploader (RabbitMQ + MinIO) ---
RABBITMQ_HOST=localhost
CLOUD_UPLOAD_QUEUE=cloud_upload_queue

CLOUD_ENDPOINT=localhost:9000
CLOUD_ACCESS_KEY=minioadmin
CLOUD_SECRET_KEY=minioadmin
CLOUD_BUCKET=retraining-data
CLOUD_SECURE=false
